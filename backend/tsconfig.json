{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "Node16",
    "moduleResolution": "Node16",
    "ignoreDeprecations": "5.0",
    "target": "es2020",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node", "jest"],
    "sourceMap": true,
    "declaration": true,
    "skipLibCheck": true,
    "strict": true,
    "isolatedModules": true,
    "moduleDetection": "force"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "generated", "prisma.config.ts", "src/**/*.test.ts"]
}
