# Database Connection - Pilih salah satu:
# 1. LOCAL XAMPP
# DATABASE_URL="mysql://root:@localhost:3306/imagenic_db"

# 2. RAILWAY MySQL (Public URL - untuk external/development)
# DATABASE_URL="mysql://root:RfhqPkIvkebMDdWpXewUgcmCAkmrhboE@acela.proxy.rlwy.net:52873/railway"

# 3. RAILWAY MySQL (Internal URL - lebih cepat jika backend juga di Railway)
# DATABASE_URL="mysql://root:RfhqPkIvkebMDdWpXewUgcmCAkmrhboE@mysql.railway.internal:3306/railway"

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# JWT Secret - GANTI dengan string random panjang di production
JWT_SECRET=your-secret-key-change-in-production

# Email Configuration (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Frontend URL
FRONTEND_URL=http://localhost:5173
